# ===== 服务端口 =====
PORT=3000

# ===== LLM（任意 OpenAI 兼容网关：OpenAI / DeepSeek / 通义 / 本地 Ollama 等） =====
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_EMBED_MODEL=text-embedding-3-small

# 未配置 API Key 时，系统以 mock 模式启动（接口仍可跑通，用于本地联调与验证）
USE_MOCK=false

# ===== Milvus (向量) =====
MILVUS_ADDRESS=localhost:19530
MILVUS_COLLECTION=cs_kb
MILVUS_DIM=1536

# ===== Elasticsearch (关键词) =====
ES_NODE=http://localhost:9200
ES_INDEX=cs_kb

# ===== PostgreSQL (业务库) =====
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=cs_kb

# ===== Redis (短期记忆) =====
REDIS_HOST=localhost
REDIS_PORT=6379
